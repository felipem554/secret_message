# Copy this file to .env and fill in the values before running docker compose.
# Never commit .env to version control.

# Redis
SPRING_REDIS_HOST=redis
SPRING_REDIS_PORT=6379
SPRING_REDIS_PASSWORD=your-secure-redis-password

# NATS (internal transport)
NATS_URL=nats://nats:4222
NATS_USER=your-nats-username
NATS_PASS=your-secure-nats-password

# Idempotency master key — MUST be overridden in production.
# Generate a secure value with: openssl rand -base64 32
IDEMPOTENCY_MASTER_KEY=CHANGE_ME

# Optional — enable JVM remote debug
# DEBUG=true
